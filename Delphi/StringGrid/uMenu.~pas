unit uMenu;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, Grids;

type
  TForm1 = class(TForm)
    grid1: TStringGrid;
    Edit1: TEdit;
    Edit2: TEdit;
    btnNovo: TButton;
    procedure FormCreate(Sender: TObject);
    procedure btnNovoClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form1: TForm1;
  cont : Integer;

implementation

{$R *.dfm}

procedure TForm1.FormCreate(Sender: TObject);
begin
  grid1.Cells[1,0] := 'Nome';
  grid1.Cells[2,0] := 'Endereþo';
  cont := 1;
  grid1.Cells[0,1] := intToStr(cont);
end;

procedure TForm1.btnNovoClick(Sender: TObject);
begin
  grid1.Cells[1,grid1.RowCount - 1] := edit1.Text;
  grid1.Cells[2,grid1.RowCount - 1] := edit2.Text;
  cont := cont + 1
  grid1.Cells[0,grid1.RowCount -1] := intToStr(cont);
  grid1.RowCount := grid1.RowCount + 1;
end;

end.
