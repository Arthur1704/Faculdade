unit uMenu;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.Menus, Vcl.StdCtrls;

type
  TfrmMenu = class(TForm)
    btnSoma: TButton;
    edtNumero1: TEdit;
    edtNumero2: TEdit;
    btnMenos: TButton;
    btnDiv: TButton;
    btnMult: TButton;
    Label1: TLabel;
    Label2: TLabel;
    procedure btnMenosClick(Sender: TObject);
  private
    { Private declarations }
  public
  function soma (num1 : double; num2 : double) : double;
  function menos (num1 : double; num2 : double) : double;
  function multiplicacao (num1 : double; num2 : double) : double;
  function divisao (num1 : double; num2 : double) : double;
  end;

var
  frmMenu: TfrmMenu;

implementation

function TfrmMenu.soma (num1 : double; num2 : double) : double;
begin
    result := num1 + num2;
end;

function TfrmMenu.menos (num1 : double; num2 : double) : double;
begin
    result := num1 - num2;
end;

function TfrmMenu.multiplicacao (num1 : double; num2 : double) : double;
begin
    result := num1 * num2;
end;

function TfrmMenu.divisao (num1 : double; num2 : double) : double;
begin
    result := num1 / num2;
end;

{$R *.dfm}

procedure TfrmMenu.btnMenosClick(Sender: TObject);
var
  num1, num2 : double;
begin

  try
    num1 := strToFloat(edtNumero1.Text);
    num2 := strToFloat(edtNumero2.Text);

    showMessage(floatToStr(soma(num1, num2)));
  except
    showMessage('Insira um numero');
  end;
end;

procedure TfrmMenu.btnMenosClick(Sender: TObject);
var
  num1, num2 : double;
begin

  try
    num1 := strToFloat(edtNumero1.Text);
    num2 := strToFloat(edtNumero2.Text);

    showMessage(floatToStr(menos(num1, num2)));
  except
    showMessage('Insira um numero');
  end;
end;

end.
