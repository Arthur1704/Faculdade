<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity2"
    tools:layout_editor_absoluteX="0dp"
    tools:layout_editor_absoluteY="-17dp"
    android:background="@color/fundo_preto">

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cadastrar Aula"
        android:textSize="34sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.023"
        android:textColor="@color/texto_branco"/>

    <EditText
        android:id="@+id/edt_titulo"
        android:layout_width="342dp"
        android:layout_height="48dp"
        android:padding="8dp"
        android:ems="10"
        android:inputType="text"
        android:text="Titulo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.637"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3"
        android:background="@color/cinza_elemento"
        android:textColor="@color/texto_branco"
        app:backgroundTint="@color/cinza_elemento"/>

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Titulo da aula"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.134"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        android:textColor="@color/texto_branco"/>

    <TextView
        android:id="@+id/textView4"
        android:layout_width="65dp"
        android:layout_height="23dp"
        android:layout_marginTop="16dp"
        android:text="Tipo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.127"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edt_data"
        android:textColor="@color/texto_branco"/>

    <Spinner
        android:id="@+id/spn_tipo"
        android:layout_width="342dp"
        android:layout_height="48dp"
        android:padding="8dp"
        android:entries="@array/tipo_aula"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.637"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView4"
        android:background="@color/cinza_elemento"
        android:textColor="@color/texto_branco"
        app:backgroundTint="@color/cinza_elemento"/>

    <EditText
        android:id="@+id/edt_conteudo"
        android:layout_width="342dp"
        android:layout_height="48dp"
        android:padding="8dp"
        android:ems="10"
        android:inputType="text"
        android:text="Conteudo aula"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.637"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView5"
        android:background="@color/cinza_elemento"
        android:textColor="@color/texto_branco"
        app:backgroundTint="@color/cinza_elemento"/>

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Conteudo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.125"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spn_tipo"
        android:textColor="@color/texto_branco"/>

    <Button
        android:id="@+id/btn_ver_aulas"
        android:layout_width="284dp"
        android:layout_height="53dp"
        android:layout_marginBottom="12dp"
        android:text="Ver Aulas"
        app:layout_constraintBottom_toTopOf="@+id/btn_excluir"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:backgroundTint="@color/vermelho_botao"
        android:textColor="@color/texto_branco"/>

    <Button
        android:id="@+id/btn_excluir"
        android:layout_width="284dp"
        android:layout_height="53dp"
        android:layout_marginBottom="28dp"
        android:text="Excluir"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:backgroundTint="@color/vermelho_botao"
        android:textColor="@color/texto_branco"/>

    <Spinner
        android:id="@+id/spn_dificuldade"
        android:layout_width="342dp"
        android:layout_height="48dp"
        android:padding="8dp"
        android:entries="@array/dificuldade"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.637"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView7"
        android:background="@color/cinza_elemento"
        android:textColor="@color/texto_branco"
        app:backgroundTint="@color/cinza_elemento"/>

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Dificuldade"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.129"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edt_titulo"
        android:textColor="@color/texto_branco"/>

    <EditText
        android:id="@+id/edt_data"
        android:layout_width="342dp"
        android:layout_height="48dp"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:inputType="date"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.637"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView8"
        android:background="@color/cinza_elemento"
        android:textColor="@color/texto_branco"
        app:backgroundTint="@color/cinza_elemento"/>

    <TextView
        android:id="@+id/textView8"
        android:layout_width="51dp"
        android:layout_height="22dp"
        android:layout_marginTop="8dp"
        android:text="Data"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.122"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spn_dificuldade"
        android:textColor="@color/texto_branco"/>

    <Button
        android:id="@+id/btn_salvar"
        android:layout_width="284dp"
        android:layout_height="53dp"
        android:layout_marginBottom="16dp"
        android:text="Salvar"
        app:layout_constraintBottom_toTopOf="@+id/btn_ver_aulas"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:backgroundTint="@color/vermelho_botao"
        android:textColor="@color/texto_branco"/>

</androidx.constraintlayout.widget.ConstraintLayout>